{
    "name": "dracula-variants",
    "version": "1.0.0",
    "displayName": "Dracula Variants",
    "homepage": "https://github.com/ZhangWillThink/dracula-variants",
    "description": "Dracula theme variants for VS Code — includes the original dark theme, soft variant, and a carefully crafted light variant.",
    "publisher": "ZhangWillThink",
    "license": "MIT",
    "scripts": {
        "build": "node ./scripts/build.js",
        "lint": "node ./scripts/lint.js",
        "package": "vsce package -o ./bin/dracula-variants.vsix",
        "vscode:prepublish": "npm run build",
        "vsce-publish": "vsce publish"
    },
    "author": "ZhangWillThink",
    "repository": {
        "type": "git",
        "url": "https://github.com/ZhangWillThink/dracula-variants.git"
    },
    "bugs": {
        "url": "https://github.com/ZhangWillThink/dracula-variants/issues"
    },
    "engines": {
        "vscode": "^1.13.0"
    },
    "categories": [
        "Themes"
    ],
    "keywords": [
        "dracula",
        "dark",
        "light",
        "theme",
        "color-theme"
    ],
    "icon": "icon.png",
    "galleryBanner": {
        "color": "#F8F8F2",
        "theme": "light"
    },
    "contributes": {
        "themes": [
            {
                "label": "Dracula Theme",
                "uiTheme": "vs-dark",
                "path": "./theme/dracula.json"
            },
            {
                "label": "Dracula Theme Soft",
                "uiTheme": "vs-dark",
                "path": "./theme/dracula-soft.json"
            },
            {
                "label": "Dracula Theme Light",
                "uiTheme": "vs",
                "path": "./theme/dracula-light.json"
            }
        ]
    },
    "devDependencies": {
        "js-yaml": "^4.1.1",
        "prettier": "^3.0.0",
        "tinycolor2": "^1.6.0",
        "vsce": "^2.15.0"
    }
}
